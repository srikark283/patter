{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Patter",
  "version": "0.3.2",
  "identifier": "com.srikar.patter",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY2NDA4MUU2QUFFODA3OTYKUldTV0IraXE1b0ZBWmlvbUs5dTVqKzFWV2Q5RXZNdUlyZXV4M2hvaXExZU1ZZGhNdlZNak5JTEQK",
      "endpoints": [
        "https://github.com/srikark283/patter/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "resources": [
      "icons/menu/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
